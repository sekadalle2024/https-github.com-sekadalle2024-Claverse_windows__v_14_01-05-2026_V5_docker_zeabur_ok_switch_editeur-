// ============================================================
// TYPES
// ============================================================

interface ModeItem {
  id: string;
  label: string;
  prefix: string;
}

interface EtapeItem {
  id: string;
  label: string;
  icon: React.ReactNode;
  command: string;
  norme?: string; // Norme d'audit associée
}

interface TestItem {
  id: string;
  reference: string;
  label: string;
  processus: string;
  command: string;
}

interface CycleComptable {
  id: string;
  label: string;
  icon: React.ReactNode;
  tests: TestItem[];
}

interface PhaseItem {
  id: string;
  label: string;
  etapes?: EtapeItem[];
  cycles?: CycleComptable[];
}

interface LogicielItem {
  id: string;
  label: string;
  icon: React.ReactNode;
  phases: PhaseItem[];
}

interface DemarrerMenuProps {
  onInsertCommand: (command: string) => void;
  disabled?: boolean;
}

// ============================================================
// MODES DISPONIBLES
// ============================================================

const MODES: ModeItem[] = [
  { id: 'normal', label: 'Normal', prefix: '' },
  { id: 'demo', label: 'Demo', prefix: '[Demo] = Activate\n' },
  { id: 'avance', label: 'Avancé', prefix: '[Mode] = Avancé\n' },
  { id: 'intelligent', label: 'Intelligent', prefix: '[Mode] = Intelligent\n' },
  { id: 'manuel', label: 'Manuel', prefix: '[Mode] = Manuel\n' }
];

